# Campus Marketplace API - Environment Configuration

# ── Database Configuration ──
# For Local MySQL (XAMPP):
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=campus_marketplace
# DB_USER=root
# DB_PASS=

# For Supabase (PostgreSQL):
DB_DRIVER=pgsql
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-supabase-password

# ── Authentication ──
# Change this to a long random string in production
JWT_SECRET=campus_mkt_jwt_secret_change_in_production
JWT_EXPIRY=604800

# ── AI Recommendation Engine ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Paystack Payment Integration ──
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...

# ── Cloudinary Media Storage ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── URLs ──
# Production frontend URL (e.g., https://your-site.netlify.app)
FRONTEND_URL=https://campusmarketplaces.netlify.app
# Absolute URL to the backend folder
APP_URL=https://campus-marketplace-api-x55w.onrender.com
APP_ENV=production
