# Disable PHP execution completely within the uploads directory.
# This serves as a secondary firewall if malicious users bypass MIME restriction filters.

php_flag engine off

# Strongly deny access to any recognizable backend scripts
<FilesMatch "\.(?i:php|php3|php4|php5|php7|php8|phtml|phar|inc|pl|py|jsp|asp|htm|html|shtml|sh|cgi)$">
    Require all denied
</FilesMatch>

# Specifically deny .htaccess visibility itself just in case
<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>
