# Campus Marketplace Frontend - Production Environment
# Set these environment variables in Netlify dashboard

# Backend API Connection
# AlwaysData hosts both frontend + backend, so use same-origin API.
VITE_API_URL=/api

# Paystack Public Key (Live)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_ba277a24ca885b3f6299a479329bcfe265132cc2

# Optional: Gemini API Key
VITE_GEMINI_API_KEY=

# App Info
VITE_APP_NAME=Campus Marketplace
VITE_APP_ENV=production
