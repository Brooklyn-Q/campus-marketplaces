# Campus Marketplace Frontend - Production Environment
# Set these environment variables in Netlify dashboard

# Backend API Connection
# Replace 'xxxxx' with your actual Render service name
VITE_API_URL=https://campus-marketplace-api.onrender.com

# Paystack Public Key (Live)
# Get from: https://dashboard.paystack.com/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxx

# Optional: Gemini API Key
VITE_GEMINI_API_KEY=

# App Info
VITE_APP_NAME=Campus Marketplace
VITE_APP_ENV=production
