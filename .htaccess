# Campus Marketplace Routing Configuration for AlwaysData

Options -Indexes
DirectoryIndex public/index.html index.php

# Protect sensitive files (env, lockfiles, git config)
<FilesMatch "\.(env|env\.local|composer\.json|composer\.lock|gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ===== API ROUTING =====
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Route /api/* to backend/index.php (keep legacy /api/*.php files)
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ backend/index.php?route=$1 [L,QSA]

    # Skip static assets and real files/dirs
    RewriteCond %{REQUEST_URI} ^/(assets|uploads|public)/ [OR]
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule .* - [L]

    # Default: serve React SPA from public/index.html
    RewriteCond %{REQUEST_URI} !\.(css|js|map|ico|png|jpg|jpeg|webp|gif|svg|mp4|woff|woff2|ttf|eot|json)$ [NC]
    RewriteRule ^(?!api/|admin/|backend/|includes/)(.*)$ /public/index.html [L,QSA]
</IfModule>

AddDefaultCharset utf-8
