# Campus Marketplace Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to git - it contains secrets

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=campus_marketplace
DB_USER=root
DB_PASS=

# ===== AUTHENTICATION =====
# Generate a strong random secret for production: openssl rand -base64 32
JWT_SECRET=your_very_strong_random_secret_here_at_least_32_chars_long
JWT_EXPIRY=604800

# ===== AI RECOMMENDATION ENGINE =====
# Get free API key from https://ai.google.dev/
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# ===== PAYMENT INTEGRATION =====
# Get keys from https://dashboard.paystack.com/
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# ===== MEDIA STORAGE (Optional) =====
# If using Cloudinary for image uploads: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== FRONTEND URL =====
# Set this in production to your frontend domain
# Example: https://marketplace.youruni.edu
FRONTEND_URL=

# ===== EMAIL (Optional) =====
# For sending notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@campus-marketplace.com

# ===== OTHER =====
APP_ENV=production
APP_DEBUG=false
